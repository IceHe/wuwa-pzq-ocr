[Unit]
Description=OCR local web service
After=network.target

[Service]
Type=simple
User=__RUN_USER__
WorkingDirectory=__PROJECT_ROOT__
Environment=HOST=0.0.0.0
Environment=PORT=8012
Environment=DEBUG=0
ExecStart=__PROJECT_ROOT__/scripts/start_web.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
